# watsonx Orchestrate Customer Complaint Agent
# Environment Configuration Template

# ============================================
# Account Service Configuration
# ============================================
ACCOUNT_SERVICE_URL=https://api.yourcompany.com/accounts
AUTH_TOKEN_URL=https://auth.yourcompany.com/oauth/token
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# ============================================
# Ticket Service Configuration
# ============================================
TICKET_SERVICE_URL=https://api.yourcompany.com/tickets
TICKET_API_KEY=your_ticket_api_key_here

# ============================================
# watsonx.ai Configuration
# ============================================
WATSONX_API_KEY=your_watsonx_api_key
WATSONX_PROJECT_ID=your_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model Configuration
WATSONX_MODEL=ibm/granite-13b-chat-v2
WATSONX_MAX_TOKENS=2048
WATSONX_TEMPERATURE=0.7
WATSONX_TOP_P=0.9

# ============================================
# Orchestrate Configuration
# ============================================
ORCHESTRATE_WORKSPACE_ID=your_workspace_id
ORCHESTRATE_API_KEY=your_orchestrate_api_key
ORCHESTRATE_REGION=us-south

# ============================================
# Agent Behavior Configuration
# ============================================
# Conversation Settings
MAX_CONVERSATION_TURNS=50
CONVERSATION_TIMEOUT=1800
ENABLE_SENTIMENT_ANALYSIS=true
SENTIMENT_CHECK_FREQUENCY=every_turn

# Escalation Thresholds
NEGATIVE_SENTIMENT_THRESHOLD=-0.7
HIGH_VALUE_BILLING_THRESHOLD=500
MAX_RETRY_ATTEMPTS=3

# ============================================
# Notification Configuration
# ============================================
# Email Settings
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=support@yourcompany.com

# SMS Settings (Optional)
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_twilio_sid
SMS_AUTH_TOKEN=your_twilio_token
SMS_FROM_NUMBER=+1234567890

# ============================================
# Logging and Monitoring
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true

# Metrics
ENABLE_METRICS=true
METRICS_ENDPOINT=https://metrics.yourcompany.com
METRICS_API_KEY=your_metrics_api_key

# ============================================
# Cache Configuration
# ============================================
CACHE_ENABLED=true
CACHE_TTL=300
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ============================================
# Security Configuration
# ============================================
# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Data Encryption
ENCRYPT_SENSITIVE_DATA=true
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# Feature Flags
# ============================================
ENABLE_KNOWLEDGE_BASE_SEARCH=true
ENABLE_AUTO_CATEGORIZATION=true
ENABLE_AUTO_ESCALATION=true
ENABLE_SENTIMENT_MONITORING=true
ENABLE_SLA_TRACKING=true

# ============================================
# Development/Testing
# ============================================
ENVIRONMENT=production
DEBUG_MODE=false
MOCK_EXTERNAL_APIS=false
TEST_MODE=false